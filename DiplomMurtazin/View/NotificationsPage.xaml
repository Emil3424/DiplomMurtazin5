<Page x:Class="DiplomMurtazin.View.NotificationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Уведомления"
      Loaded="Page_Loaded"
      Background="#ecf0f1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Уведомления о внешних изменениях"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#2c3e50"
                       Margin="0,0,20,0"/>
            <Button Content="Обновить"
                    Width="100"
                    Height="36"
                    Command="{Binding RefreshCommand}"
                    Background="#3498db"
                    Foreground="White"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#bdc3c7"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding EventDate, StringFormat=dd.MM.yyyy HH:mm:ss}" Width="170"/>
                <DataGridTextColumn Header="Пользователь" Binding="{Binding UserLogin}" Width="120"/>
                <DataGridTextColumn Header="Действие" Binding="{Binding ActionType}" Width="120"/>
                <DataGridTextColumn Header="Сущность" Binding="{Binding EntityType}" Width="130"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Details}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2"
                Background="{Binding StatusColor}"
                CornerRadius="6"
                Padding="10"
                Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>
