<Page x:Class="DiplomMurtazin.View.ReturnProcessingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оформление возврата"
      Loaded="Page_Loaded"
      Background="#ecf0f1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Оформление возврата" FontSize="26" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,20,0"/>
            <TextBox Width="250" Height="34" Margin="0,0,8,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Найти" Width="90" Height="34" Command="{Binding RefreshCommand}" Background="#3498db" Foreground="White"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>
            <DataGrid ItemsSource="{Binding SoldUnits}" SelectedItem="{Binding SelectedUnit}" AutoGenerateColumns="False" IsReadOnly="True" Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="UnitID" Binding="{Binding UnitID}" Width="70"/>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Продан" Binding="{Binding SoldDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Возврат до" Binding="{Binding ReturnEndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Гарантия до" Binding="{Binding WarrantyEndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:F2} ₽}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Margin="10,0,0,0" Background="White" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="Причина возврата" FontWeight="SemiBold"/>
                    <TextBox Height="80" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding ReturnReason, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>
                    <TextBlock Text="Комментарий менеджера" FontWeight="SemiBold"/>
                    <TextBox Height="80" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding ManagerComment, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>
                    <Button Content="Оформить возврат и выдать чек" Height="36" Command="{Binding ProcessReturnCommand}" Background="#e67e22" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{Binding StatusColor}" CornerRadius="5" Padding="10" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White"/>
        </Border>
    </Grid>
</Page>
