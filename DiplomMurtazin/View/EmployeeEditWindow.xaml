<Window x:Class="DiplomMurtazin.View.EmployeeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" 
        Height="650" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#f5f7fa">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#bdc3c7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#bdc3c7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="FormDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#bdc3c7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="FormCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#3498db" 
                CornerRadius="5" 
                Padding="15" 
                Margin="0,0,0,20">
            <TextBlock Text="{Binding Title}" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" 
                        Padding="15" 
                        CornerRadius="5" 
                        BorderBrush="#bdc3c7"
                        BorderThickness="1"
                        Margin="0,0,0,20">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="120" Height="150"
                                CornerRadius="5"
                                BorderBrush="#3498db"
                                BorderThickness="2"
                                Margin="0,0,20,0"
                                Background="#f0f0f0">
                            <Image x:Name="PreviewImage"
                                   Source="{Binding PhotoPreview}"
                                   Stretch="UniformToFill"
                                   VerticalAlignment="Center">
                                <Image.Clip>
                                    <RectangleGeometry Rect="0,0,120,150" RadiusX="5" RadiusY="5"/>
                                </Image.Clip>
                            </Image>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Фотография сотрудника" 
                                       FontSize="16" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <Button Content=" Выбрать фото" 
                                    Width="150" Height="35"
                                    Margin="0,0,0,10"
                                    Command="{Binding SelectPhotoCommand}"
                                    Background="#3498db" 
                                    Foreground="White"
                                    Cursor="Hand"/>

                            <Button Content=" Удалить фото" 
                                    Width="150" Height="35"
                                    Command="{Binding ClearPhotoCommand}"
                                    Background="#e74c3c" 
                                    Foreground="White"
                                    Cursor="Hand"/>

                            <TextBlock Text="Рекомендуемый размер: 300×400px" 
                                       FontSize="10" 
                                       Foreground="#7f8c8d"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Фамилия *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Employee.LastName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource FormTextBox}"/>

                        <TextBlock Text="Имя *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Employee.FirstName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource FormTextBox}"/>

                        <TextBlock Text="Отчество" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Employee.MiddleName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource FormTextBox}"/>

                        <TextBlock Text="Должность" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding Positions}"
                                  SelectedItem="{Binding SelectedPosition}"
                                  DisplayMemberPath="PositionName"
                                  Style="{StaticResource FormComboBox}"/>

                        <TextBlock Text="Дата приема" Style="{StaticResource FormLabel}"/>
                        <DatePicker SelectedDate="{Binding Employee.HireDate}" 
                                    Style="{StaticResource FormDatePicker}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Телефон" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Employee.Phone}" 
         Style="{StaticResource FormTextBox}"
         Loaded="PhoneTextBox_Loaded"/>

                        <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Employee.Email}" 
         Style="{StaticResource FormTextBox}"/>

                        <TextBlock Text="Адрес" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Employee.Address, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource FormTextBox}"/>

                        <TextBlock Text="Паспортные данные" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Employee.PassportData}" 
         Style="{StaticResource FormTextBox}"
         Loaded="PassportTextBox_Loaded"/>


                        <TextBlock Text="ИНН" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Employee.INN}" 
         Style="{StaticResource FormTextBox}"
         Loaded="InnTextBox_Loaded"/>

                        <CheckBox Content="Активный сотрудник" 
                                  IsChecked="{Binding Employee.IsActive}"
                                  Style="{StaticResource FormCheckBox}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="* - обязательные поля" 
                           FontSize="11" 
                           Foreground="#95a5a6"
                           FontStyle="Italic"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button Content=" Сохранить" 
                    Width="120" Height="40" Margin="5"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="#27ae60" 
                    Foreground="White"
                    Cursor="Hand"/>

            <Button Content=" Отмена" 
                    Width="120" Height="40" Margin="5"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="#e74c3c" 
                    Foreground="White"
                    Cursor="Hand"/>
        </StackPanel>

        <Border Grid.Row="3"
                x:Name="ErrorBorder"
                Background="#e74c3c"
                CornerRadius="5"
                Padding="10"
                Margin="0,15,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="White"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,30,0"/>
                <Button Content="X"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseErrorButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>