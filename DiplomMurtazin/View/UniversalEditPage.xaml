<Page x:Class="DiplomMurtazin.View.UniversalEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:core="clr-namespace:DiplomMurtazin.Core"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      Title="Редактирование таблиц"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded"
      Background="#ecf0f1">

    <Page.Resources>
        <core:TextToVisibilityConverter x:Key="TextToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Редактирование таблиц" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#2c3e50"
                       Margin="0,0,30,0"
                       VerticalAlignment="Center"/>

            <Button Content=" Сохранить" 
                    Width="120" Height="40" Margin="5"
                    Command="{Binding SaveCommand}"
                    Background="#27ae60" 
                    Foreground="White"
                    Cursor="Hand"/>

            <Button Content=" Добавить" 
                    Width="100" Height="40" Margin="5"
                    Click="AddButton_Click"
                    Background="#f39c12" 
                    Foreground="White"
                    Cursor="Hand"/>

            <Button Content=" Удалить" 
                    Width="100" Height="40" Margin="5"
                    Click="DeleteButton_Click"
                    Background="#e74c3c" 
                    Foreground="White"
                    Cursor="Hand"/>

            <Button Content=" Обновить" 
                    Width="100" Height="40" Margin="5"
                    Command="{Binding RefreshCommand}"
                    Background="#3498db" 
                    Foreground="White"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Панель выбора таблицы и поиска -->
        <Border Grid.Row="1" 
                Background="White" 
                Padding="15" 
                CornerRadius="5" 
                Margin="0,0,0,20"
                BorderBrush="#bdc3c7"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="225"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Выбор таблицы -->
                <TextBlock Grid.Column="0" 
                           Text="Таблица:" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox Grid.Column="1" 
                          Width="200" 
                          Height="35"
                          ItemsSource="{Binding Tables}"
                          SelectedItem="{Binding SelectedTable}"
                          DisplayMemberPath="Name"
                          Margin="0,0,20,0"/>

                <!-- Поиск -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Поиск:" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <TextBox Width="250" 
                             Height="35"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                             Padding="10,5"
                             BorderBrush="#3498db"
                             BorderThickness="1"/>
                </StackPanel>

                <!-- Кнопка сброса -->
                <Button Grid.Column="3" 
                        Content="Сбросить" 
                        Width="80" 
                        Height="35"
                        Margin="20,0,0,0"
                        Command="{Binding ResetFiltersCommand}"
                        Background="#95a5a6" 
                        Foreground="White"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- DataGrid для отображения данных -->
        <DataGrid Grid.Row="2"
                  x:Name="MainDataGrid"
                  ItemsSource="{Binding DataTable}"
                  AutoGenerateColumns="True"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  Background="White"
                  BorderBrush="#bdc3c7"
                  BorderThickness="1"
                  AlternatingRowBackground="#f2f6f9"
                  FontSize="12"
                  Margin="0,0,0,10"/>

        <!-- Статус бар -->
        <Border Grid.Row="3" 
                Background="{Binding StatusColor}"
                Padding="10"
                CornerRadius="5">
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="White"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>