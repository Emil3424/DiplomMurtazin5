<Page x:Class="DiplomMurtazin.View.SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:core="clr-namespace:DiplomMurtazin.Core"
      Title="Продажи"
      Loaded="Page_Loaded"
      Background="#ecf0f1">

    <Page.Resources>
        <core:TextToVisibilityConverter x:Key="TextToVisibilityConverter"/>
        <core:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <core:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть - каталог товаров -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" 
                       Text="Каталог товаров" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#2c3e50"
                       Margin="0,0,0,15"/>

            <!-- Панель поиска и фильтрации -->
            <Border Grid.Row="1" 
                    Background="White" 
                    Padding="15" 
                    CornerRadius="5" 
                    Margin="0,0,0,15"
                    BorderBrush="#bdc3c7"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Поиск по названию -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="Поиск:" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <TextBox Width="250" 
                                 Height="35"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                                 Padding="10,5"
                                 BorderBrush="#3498db"
                                 BorderThickness="1">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border CornerRadius="5" 
                                            Background="White" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <Grid>
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0"/>
                                            <TextBlock x:Name="PlaceholderText" 
                                                      Text="Название товара..." 
                                                      Foreground="#95a5a6" 
                                                      IsHitTestVisible="False"
                                                      Margin="10,0"
                                                      VerticalAlignment="Center"
                                                      Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                    </StackPanel>

                    <!-- Фильтр по категории -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Категория:" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <ComboBox Width="180" 
                                  Height="35"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategoryFilter}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CategoryName}" FontSize="14"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Кнопка сброса -->
                    <Button Grid.Column="2" 
                            Content="Сбросить" 
                            Width="80" 
                            Height="35"
                            Margin="20,0,0,0"
                            Command="{Binding ResetFiltersCommand}"
                            Background="#95a5a6" 
                            Foreground="White"
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- DataGrid товаров -->
            <DataGrid Grid.Row="2"
                      x:Name="ProductsDataGrid"
                      ItemsSource="{Binding FilteredProducts}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      Background="White"
                      BorderBrush="#bdc3c7"
                      BorderThickness="1"
                      AlternatingRowBackground="#f2f6f9"
                      FontSize="12"
                      MouseDoubleClick="ProductDataGrid_MouseDoubleClick">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="250"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:F2} ₽}" Width="100"/>
                    <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="80"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Categories.CategoryName}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Правая часть - текущий чек -->
        <Grid Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Текущий чек" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#2c3e50"
                       Margin="0,0,0,20"/>

            <!-- Список товаров в чеке -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding SaleItems}"
                      SelectedItem="{Binding SelectedSaleItem}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Background="White"
                      BorderBrush="#bdc3c7"
                      BorderThickness="1"
                      FontSize="12"
                      Height="300"
                      SelectionChanged="DataGrid_SelectionChanged">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="70" IsReadOnly="False"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:F2} ₽}" Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice, StringFormat={}{0:F2} ₽}" Width="80" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Блок ошибок по остаткам -->
            <Border Grid.Row="2" 
                    Background="#e74c3c"
                    CornerRadius="5"
                    Padding="10"
                    Margin="0,10"
                    Visibility="{Binding HasStockErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding StockError}" 
                           Foreground="White"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Кнопки управления чеком -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <Button Content="Удалить" 
                        Width="100" Height="35" Margin="5"
                        Command="{Binding RemoveFromSaleCommand}"
                        Background="#e74c3c" Foreground="White"
                        Cursor="Hand"/>

                <Button Content="Очистить" 
                        Width="100" Height="35" Margin="5"
                        Command="{Binding ClearSaleCommand}"
                        Background="#95a5a6" Foreground="White"
                        Cursor="Hand"/>
            </StackPanel>

            <!-- Итого -->
            <Border Grid.Row="4" 
                    Background="#3498db" 
                    CornerRadius="5" 
                    Padding="15"
                    Margin="0,10">
                <StackPanel>
                    <TextBlock Text="ИТОГО:" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:F2} ₽}" 
                               FontSize="32" 
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <!-- Кнопка оплаты -->
            <Button Grid.Row="5" 
                    Content=" Оформить продажу" 
                    Height="50"
                    FontSize="18"
                    FontWeight="Bold"
                    Command="{Binding CompleteSaleCommand}"
                    Background="#27ae60" 
                    Foreground="White"
                    Cursor="Hand"
                    Margin="0,10"
                    IsEnabled="{Binding HasStockErrors, Converter={StaticResource InverseBooleanConverter}}"/>
        </Grid>
    </Grid>
</Page>