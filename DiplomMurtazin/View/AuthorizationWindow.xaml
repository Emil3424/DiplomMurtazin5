<Window x:Class="DiplomMurtazin.View.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - KPMurtazin" 
        Height="500" 
        Width="450"
        MinHeight="500" 
        MinWidth="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        SizeToContent="Height">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Style="{StaticResource HeaderText}" 
                   Text="Вход в систему"
                   FontSize="28"/>

        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock Text="Логин:" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="LoginTextBox"
                     Style="{StaticResource RoundedTextBox}" 
                     Height="40"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <TextBlock Text="Пароль:" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            <Grid>
                <PasswordBox x:Name="PasswordBox" 
                             Style="{StaticResource RoundedPasswordBox}"
                             Height="40"
                             Padding="10,5,40,5"
                             PasswordChanged="PasswordBox_PasswordChanged"/>
                <TextBox x:Name="PasswordTextBox"
                         Style="{StaticResource RoundedTextBox}"
                         Height="40"
                         Padding="10,5,40,5"
                         Visibility="Collapsed"
                         TextChanged="PasswordTextBox_TextChanged"/>
                <Button x:Name="TogglePasswordButton"
                        Width="26"
                        Height="26"
                        Content="👁"
                        FontSize="14"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        ToolTip="Показать/скрыть пароль"
                        Click="TogglePasswordVisibility_Click"/>
            </Grid>
        </StackPanel>

        <Border x:Name="ErrorBorder"
                Grid.Row="3" 
                Margin="0,15,0,0"
                Background="#FFffee"
                BorderBrush="#e74c3c"
                BorderThickness="1"
                CornerRadius="5"
                Visibility="Collapsed">
            <Grid>
                <TextBlock x:Name="ErrorText" 
                           Foreground="#e74c3c" 
                           Margin="10,10,30,10"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"/>
                <Button Content="X"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,5,5,0"
                        Click="CloseErrorButton_Click"/>
            </Grid>
        </Border>

        <Button Grid.Row="4" 
                x:Name="LoginButton"
                Style="{StaticResource PrimaryButton}"
                Content="Войти"
                Height="45"
                FontSize="18"
                Margin="0,20,0,10"
                Click="LoginButton_Click"/>

        <Border Grid.Row="5" 
                Height="1" 
                Background="#CCCCCC" 
                Margin="0,20,0,10"/>

        <StackPanel Grid.Row="6" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="Нет аккаунта? " 
                       FontSize="14"
                       Foreground="#666666"/>
            <TextBlock Text="Зарегистрироваться"
                       FontSize="14"
                       Foreground="#3498db"
                       FontWeight="Bold"
                       TextDecorations="Underline"
                       Cursor="Hand"
                       MouseLeftButtonDown="RegistrationLink_MouseLeftButtonDown"/>
        </StackPanel>
    </Grid>
</Window>