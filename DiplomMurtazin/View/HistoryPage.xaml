<Page x:Class="DiplomMurtazin.View.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="История действий"
      Loaded="Page_Loaded"
      Background="#ecf0f1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="История действий"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="#2c3e50"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#bdc3c7"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,15">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Height="34"
                             Margin="0,0,10,0"
                             Padding="10,5"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Поиск по пользователю, действию, сущности, описанию"/>

                    <ComboBox Grid.Column="1"
                              Height="34"
                              Margin="0,0,10,0"
                              ItemsSource="{Binding ActionTypes}"
                              SelectedItem="{Binding SelectedActionType}"/>

                    <ComboBox Grid.Column="2"
                              Height="34"
                              Margin="0,0,10,0"
                              ItemsSource="{Binding EntityTypes}"
                              SelectedItem="{Binding SelectedEntityType}"/>

                    <Button Grid.Column="3"
                            Content="Применить"
                            Width="100"
                            Height="34"
                            Margin="0,0,8,0"
                            Command="{Binding ApplyFilterCommand}"
                            Background="#3498db"
                            Foreground="White"/>

                    <Button Grid.Column="4"
                            Content="Сбросить"
                            Width="100"
                            Height="34"
                            Command="{Binding ResetFiltersCommand}"
                            Background="#95a5a6"
                            Foreground="White"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Дата с:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="2" Text="Дата по:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}" Margin="0,0,12,0"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Обновить" Width="90" Height="32" Margin="0,0,8,0"
                                Command="{Binding RefreshCommand}" Background="#16a085" Foreground="White"/>
                        <Button Content="PDF" Width="70" Height="32" Margin="0,0,6,0"
                                Command="{Binding ExportPdfCommand}" Background="#2c3e50" Foreground="White"/>
                        <Button Content="CSV" Width="70" Height="32" Margin="0,0,6,0"
                                Command="{Binding ExportCsvCommand}" Background="#27ae60" Foreground="White"/>
                        <Button Content="Excel" Width="70" Height="32"
                                Command="{Binding ExportExcelCommand}" Background="#8e44ad" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  Background="White"
                  BorderBrush="#bdc3c7"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding EventDate, StringFormat=dd.MM.yyyy HH:mm:ss}" Width="160"/>
                <DataGridTextColumn Header="Пользователь" Binding="{Binding UserLogin}" Width="120"/>
                <DataGridTextColumn Header="Действие" Binding="{Binding ActionType}" Width="120"/>
                <DataGridTextColumn Header="Сущность" Binding="{Binding EntityType}" Width="140"/>
                <DataGridTextColumn Header="ID" Binding="{Binding EntityID}" Width="90"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Details}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3"
                Background="{Binding StatusColor}"
                CornerRadius="6"
                Padding="10"
                Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>
