<Page x:Class="DiplomMurtazin.View.ViewDisplayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:core="clr-namespace:DiplomMurtazin.Core"
      Title="Просмотр представлений"
      Loaded="Page_Loaded"
      Background="#ecf0f1">

    <Page.Resources>
        <core:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Просмотр представлений" 
               FontSize="32" 
               FontWeight="Bold"
               Foreground="#2c3e50"
               Margin="0,0,30,0"
               VerticalAlignment="Center"/>

            <Button Content="Экспорт в Excel" 
            Width="150" Height="40" Margin="5"
            Command="{Binding ExportToExcelCommand}"
            Background="#27ae60" 
            Foreground="White"
            Cursor="Hand"
            Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <Button Content=" Обновить" 
            Width="100" Height="40" Margin="5"
            Command="{Binding RefreshCommand}"
            Background="#3498db" 
            Foreground="White"
            Cursor="Hand"/>
        </StackPanel>

        <!-- Панель выбора представления -->
        <Border Grid.Row="1" 
                Background="White" 
                Padding="15" 
                CornerRadius="5" 
                Margin="0,0,0,20"
                BorderBrush="#bdc3c7"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="225"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Представление:" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox Grid.Column="1" 
                          Width="200" 
                          Height="35"
                          ItemsSource="{Binding SavedViews}"
                          SelectedItem="{Binding SelectedView}"
                          DisplayMemberPath="Name"
                          Margin="0,0,20,0"/>

                <TextBlock Grid.Column="2" 
                           Text="{Binding ViewInfo}"
                           FontSize="12"
                           Foreground="#7f8c8d"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="3" 
                        Content="Показать" 
                        Width="100" 
                        Height="35"
                        Command="{Binding LoadViewCommand}"
                        Background="#3498db" 
                        Foreground="White"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- DataGrid для отображения данных -->
        <DataGrid Grid.Row="2"
          x:Name="ViewDataGrid"
          ItemsSource="{Binding ViewData}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          Background="White"
          BorderBrush="#bdc3c7"
          BorderThickness="1"
          AlternatingRowBackground="#f2f6f9"
          FontSize="12"
          Margin="0,0,0,10"
          Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}"
          AutoGeneratingColumn="ViewDataGrid_AutoGeneratingColumn">

            <!-- Колонки генерируются динамически в коде -->
        </DataGrid>

        <!-- Сообщение если нет данных -->
        <Border Grid.Row="2" 
                Background="White" 
                Padding="30" 
                CornerRadius="5" 
                Margin="0,0,0,10"
                BorderBrush="#bdc3c7"
                BorderThickness="1"
                Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Выберите представление для просмотра" 
                           FontSize="16" 
                           Foreground="#7f8c8d"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Статус бар -->
        <Border Grid.Row="3" 
                Background="{Binding StatusColor}"
                Padding="10"
                CornerRadius="5">
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="White"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>