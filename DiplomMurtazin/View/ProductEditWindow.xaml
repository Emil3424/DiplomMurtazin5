<Window x:Class="DiplomMurtazin.View.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" 
        MinHeight="600" 
        MinWidth="500"
        Height="auto" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="#f5f7fa">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Простой стиль для TextBox -->
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#bdc3c7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- Простой стиль для ComboBox (убрана кастомная шаблонизация) -->
        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#bdc3c7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- Стиль для TextBox с большой высотой (для описания) -->
        <Style x:Key="DescriptionTextBox" TargetType="TextBox" BasedOn="{StaticResource FormTextBox}">
            <Setter Property="Height" Value="80"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="#3498db" 
                CornerRadius="5" 
                Padding="15" 
                Margin="0,0,0,20">
            <TextBlock Text="{Binding Title}" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <!-- Наименование товара -->
                <TextBlock Text="Наименование товара *" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Product.ProductName, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource FormTextBox}"/>

                <!-- Штрих-код -->
                <TextBlock Text="Штрих-код *" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Product.Barcode}" 
         Style="{StaticResource FormTextBox}"
         Loaded="BarcodeTextBox_Loaded"/>

                <!-- Категория - простой ComboBox -->
                <TextBlock Text="Категория" Style="{StaticResource FormLabel}"/>
                <ComboBox ItemsSource="{Binding Categories}" 
                          SelectedItem="{Binding SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="CategoryName"
                          Style="{StaticResource FormComboBox}"/>

                <!-- Производитель -->
                <TextBlock Text="Производитель" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Product.Manufacturer, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource FormTextBox}"/>

                <!-- Модель -->
                <TextBlock Text="Модель" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Product.Model, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource FormTextBox}"/>

                <!-- Цена -->
                <TextBlock Text="Цена *" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Product.UnitPrice}" 
         Style="{StaticResource FormTextBox}"
         Loaded="PriceTextBox_Loaded"/>

                <!-- Гарантия (мес) -->
                <TextBlock Text="Гарантия (месяцев)" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Product.WarrantyMonths, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource FormTextBox}" Loaded="QuantityTextBox_Loaded"/>

                <!-- Минимальный остаток -->
                <TextBlock Text="Минимальный остаток" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Product.MinStockLevel}" 
         Style="{StaticResource FormTextBox}"
         Loaded="QuantityTextBox_Loaded"/>

                <!-- Описание -->
                <TextBlock Text="Описание" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Product.Description, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource DescriptionTextBox}"/>

                <!-- Подсказка об обязательных полях -->
                <TextBlock Text="* - обязательные поля" 
                           FontSize="11" 
                           Foreground="#95a5a6"
                           FontStyle="Italic"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button Content=" Сохранить" 
                    Width="120" 
                    Height="40" 
                    Margin="0,0,10,0"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="#27ae60" 
                    Foreground="White"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="5" 
                                            Background="{TemplateBinding Background}" 
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2ecc71"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content=" Отмена" 
                    Width="120" 
                    Height="40" 
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="#e74c3c" 
                    Foreground="White"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="5" 
                                            Background="{TemplateBinding Background}" 
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#c0392b"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Сообщение об ошибке -->
        <Border x:Name="ErrorBorder"
        Grid.Row="2" 
        Background="#e74c3c"
        CornerRadius="5"
        Padding="10"
        Margin="0,20,0,0"
        Visibility="Collapsed"
        HorizontalAlignment="Stretch">
            <Grid>
                <TextBlock x:Name="ErrorText" 
                           Text="{Binding ErrorMessage}"
                           Foreground="White"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,30,0"/>
                <Button Content="X"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,0,0,0"
                        Click="CloseErrorButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>