<Page x:Class="DiplomMurtazin.View.ProductUnitHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="История товара"
      Loaded="Page_Loaded"
      Background="#ecf0f1">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBox Height="34" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Поиск товара"/>
            <DataGrid Grid.Row="1" Margin="0,10,0,0"
                      ItemsSource="{Binding FilteredProducts}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="ШК" Binding="{Binding Barcode}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="История индивидуального товара" FontSize="24" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,10"/>

            <DataGrid Grid.Row="1" Margin="0,0,0,10"
                      ItemsSource="{Binding Units}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True" Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="UnitID" Binding="{Binding UnitID}" Width="70"/>
                    <DataGridTextColumn Header="Продан" Binding="{Binding SoldDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Возврат до" Binding="{Binding ReturnEndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Гарантия до" Binding="{Binding WarrantyEndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Timeline}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True" Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding EventDate, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding EventType}" Width="150"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="3" Background="{Binding StatusColor}" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="White"/>
            </Border>
        </Grid>
    </Grid>
</Page>
