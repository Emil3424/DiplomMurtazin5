<Window x:Class="DiplomMurtazin.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModel="clr-namespace:DiplomMurtazin.ViewModel"
        Title="KPMurtazin - Торговая система" 
        Height="700" 
        Width="1200"
        MinHeight="600" 
        MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2c3e50">
            <!-- Добавляем ScrollViewer -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="#3498db" Padding="20" Margin="0,0,0,20">
                        <TextBlock Text="KPMurtazin" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                    </Border>

                    <Border Background="#34495e" Padding="15" Margin="10,0,10,20" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="Пользователь:" Foreground="#bdc3c7" FontSize="12"/>
                            <TextBlock Text="{Binding CurrentUser.Login}" 
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold"/>
                            <TextBlock Text="{Binding CurrentUser.Role}" 
                               Foreground="#3498db" 
                               FontSize="14"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки навигации -->
                    <RadioButton Content="Продажи" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Sales"
                         IsChecked="{Binding IsSalesSelected}"
                         Style="{StaticResource NavButtonStyle}"/>

                    <RadioButton Content="Товары" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Products"
                         IsChecked="{Binding IsProductsSelected}"
                         Style="{StaticResource NavButtonStyle}"/>

                    <RadioButton Content=" Все таблицы" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Universal"
                         Style="{StaticResource NavButtonStyle}" Cursor="Hand"/>

                    <RadioButton Content=" Сотрудники" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Employees"
                         Style="{StaticResource NavButtonStyle}"/>

                    <RadioButton Content=" Отчеты" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Reports"
                         Style="{StaticResource NavButtonStyle}"/>

                    <RadioButton Content=" ТОРГ-12" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Torg12"
                         Style="{StaticResource NavButtonStyle}"/>

                    <RadioButton Content=" История" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="History"
                         Style="{StaticResource NavButtonStyle}"/>

                    <RadioButton Content="Представления" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="ViewSettings"
                         Style="{StaticResource NavButtonStyle}"/>

                    <RadioButton Content="Просмотр представлений" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="ViewDisplay"
                         Style="{StaticResource NavButtonStyle}"/>

                    <RadioButton Content=" Уведомления" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="Notifications"
                         Style="{StaticResource NavButtonStyle}"/>

                    <RadioButton Content=" Возвраты и гарантия" 
                         Command="{Binding NavigateCommand}"
                         CommandParameter="ReturnsWarranty"
                         Style="{StaticResource NavButtonStyle}"/>

                <RadioButton Content=" Оформление возврата" 
             Command="{Binding NavigateCommand}"
             CommandParameter="ReturnProcessing"
             Style="{StaticResource NavButtonStyle}"/>

                <RadioButton Content=" История индивидуального товара" 
             Command="{Binding NavigateCommand}"
             CommandParameter="ProductUnitHistory"
             Style="{StaticResource NavButtonStyle}"/>

                    <Separator Background="#7f8c8d" Margin="10"/>

                    <Button Content="🚪 Выйти" 
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource LogoutButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Frame Grid.Column="1" 
               x:Name="MainFrame"
               NavigationUIVisibility="Hidden"
               Background="#ecf0f1"/>
    </Grid>
</Window>