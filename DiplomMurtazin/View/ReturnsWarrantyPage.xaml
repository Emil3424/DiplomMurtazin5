<Page x:Class="DiplomMurtazin.View.ReturnsWarrantyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Возвраты и гарантия"
      Loaded="Page_Loaded"
      Background="#ecf0f1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Возвраты / Гарантия / История товара" FontSize="26" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,20,0"/>
            <TextBox Width="240" Height="34" Margin="0,0,8,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Найти" Width="90" Height="34" Command="{Binding RefreshCommand}" Background="#3498db" Foreground="White"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding SoldUnits}"
                  SelectedItem="{Binding SelectedUnit}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#bdc3c7"
                  BorderThickness="1"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="UnitID" Binding="{Binding UnitID}" Width="70"/>
                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Дата продажи" Binding="{Binding SoldDate, StringFormat=dd.MM.yyyy}" Width="130"/>
                <DataGridTextColumn Header="Возврат до" Binding="{Binding ReturnEndDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                <DataGridTextColumn Header="Гарантия до" Binding="{Binding WarrantyEndDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:F2} ₽}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Width="500" Height="34" Margin="0,0,8,0" Text="{Binding ReturnReason, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Оформить возврат" Width="170" Height="34" Command="{Binding ProcessReturnCommand}" Background="#e67e22" Foreground="White"/>
        </StackPanel>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding ProductTimeline}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#bdc3c7"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding EventDate, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Тип события" Binding="{Binding EventType}" Width="160"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4" Background="{Binding StatusColor}" CornerRadius="5" Padding="10" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>
