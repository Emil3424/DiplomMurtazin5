<Page x:Class="DiplomMurtazin.View.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:core="clr-namespace:DiplomMurtazin.Core"
      Title="Сотрудники"
      Loaded="Page_Loaded"
      Background="#ecf0f1">

    <Page.Resources>
        <core:DateToStringConverter x:Key="DateToStringConverter"/>
        <core:TextToVisibilityConverter x:Key="TextToVisibilityConverter"/>

        <!-- Стиль для карточки -->
        <Style x:Key="EmployeeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#bdc3c7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#888888" Opacity="0.3" BlurRadius="5" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Сотрудники" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#2c3e50"
                       Margin="0,0,30,0"
                       VerticalAlignment="Center"/>

            <Button Content=" Добавить" 
                    Width="100" Height="40" Margin="5"
                    Command="{Binding AddCommand}"
                    Background="#27ae60" 
                    Foreground="White"
                    Cursor="Hand"/>

            <Button Content=" Редактировать" 
                    Width="100" Height="40" Margin="5"
                    Command="{Binding EditCommand}"
                    Background="#f39c12" 
                    Foreground="White"
                    Cursor="Hand"/>

            <Button Content=" Удалить" 
                    Width="100" Height="40" Margin="5"
                    Command="{Binding DeleteCommand}"
                    Background="#e74c3c" 
                    Foreground="White"
                    Cursor="Hand"/>

            <Button Content=" Обновить" 
                    Width="100" Height="40" Margin="5"
                    Command="{Binding RefreshCommand}"
                    Background="#3498db" 
                    Foreground="White"
                    Cursor="Hand"/>
        </StackPanel>

        <Border Grid.Row="1" 
                Background="White" 
                Padding="15" 
                CornerRadius="5" 
                Margin="0,0,0,20"
                BorderBrush="#bdc3c7"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Поиск:" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <TextBox Width="200" 
                             Height="35"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=500}"
                             Padding="10,5"
                             BorderBrush="#3498db"
                             BorderThickness="1">
                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <Border CornerRadius="5" 
                                        Background="White" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <Grid>
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,0"/>
                                        <TextBlock x:Name="PlaceholderText" 
                                                  Text="ФИО, email, телефон..." 
                                                  Foreground="#95a5a6" 
                                                  IsHitTestVisible="False"
                                                  Margin="10,0"
                                                  VerticalAlignment="Center"
                                                  Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                                    </Trigger>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </TextBox.Template>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text=" Должность:" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <ComboBox Width="150" 
                              Height="35"
                              ItemsSource="{Binding Positions}"
                              SelectedItem="{Binding SelectedPositionFilter}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PositionName}" FontSize="14"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Сортировка:" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <ComboBox Width="150" 
                              Height="35"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSortOption}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="14"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Button Grid.Column="3" 
                        Content="Сбросить" 
                        Width="80" 
                        Height="35"
                        Command="{Binding ResetFiltersCommand}"
                        Background="#95a5a6" 
                        Foreground="White"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <ItemsControl ItemsSource="{Binding FilteredEmployees}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource EmployeeCardStyle}"
                                Width="320"
                                Height="160"
                                MouseLeftButtonDown="EmployeeCard_MouseLeftButtonDown"
                                Tag="{Binding}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="90" Height="110"
                                        CornerRadius="5"
                                        BorderBrush="#3498db"
                                        BorderThickness="2"
                                        Margin="0,0,15,0"
                                        Background="#f0f0f0">
                                    <Image Source="{Binding Photo}"
                                           Stretch="UniformToFill"
                                           VerticalAlignment="Center">
                                        <Image.Clip>
                                            <RectangleGeometry Rect="0,0,90,110" RadiusX="5" RadiusY="5"/>
                                        </Image.Clip>
                                    </Image>
                                </Border>

                                <StackPanel Grid.Column="1" 
                                            VerticalAlignment="Center">

                                    <TextBlock Text="{Binding FullName}" 
                                               FontSize="14" 
                                               FontWeight="Bold"
                                               Foreground="#2c3e50"
                                               Margin="0,0,0,5"/>

                                    <TextBlock Text="{Binding Positions.PositionName}" 
                                               FontSize="12"
                                               Foreground="#3498db"
                                               Margin="0,0,0,5"/>

                                    <TextBlock FontSize="11">
                                        <Run Text="📅 "/>
                                        <Run Text="{Binding HireDate, Converter={StaticResource DateToStringConverter}}"/>
                                    </TextBlock>

                                    <TextBlock Text="{Binding Email}" 
                                               FontSize="11"
                                               Foreground="#7f8c8d"/>

                                    <TextBlock Text="{Binding Phone}" 
                                               FontSize="11"
                                               Foreground="#7f8c8d"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" 
                Background="{Binding StatusColor}"
                Padding="10"
                CornerRadius="5"
                Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusMessage}" 
                           Foreground="White"
                           FontWeight="SemiBold"/>

                <TextBlock Grid.Column="1" 
                           Text="{Binding FilteredEmployees.Count, StringFormat=Показано: {0} из {1}}"
                           Foreground="White"
                           FontWeight="SemiBold"
                           Margin="20,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Page>