<Window x:Class="DiplomMurtazin.View.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация - KPMurtazin" 
        Height="800" 
        Width="500"
        MinHeight="800" 
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        SizeToContent="Height">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Style="{StaticResource HeaderText}" 
                   Text="Регистрация"
                   FontSize="28"/>

        <!-- Логин -->
        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock Text="Логин *:" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="LoginTextBox"
                     Style="{StaticResource RoundedTextBox}" 
                     Height="40"/>
        </StackPanel>

        <!-- Пароль -->
        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <TextBlock Text="Пароль *:" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            <Grid>
                <PasswordBox x:Name="PasswordBox" 
                             Style="{StaticResource RoundedPasswordBox}"
                             Height="40"
                             Padding="10,5,40,5"
                             PasswordChanged="PasswordBox_PasswordChanged"/>
                <TextBox x:Name="PasswordTextBox"
                         Style="{StaticResource RoundedTextBox}"
                         Height="40"
                         Padding="10,5,40,5"
                         Visibility="Collapsed"
                         TextChanged="PasswordTextBox_TextChanged"/>
                <Button x:Name="TogglePasswordButton"
                        Width="26"
                        Height="26"
                        Content="👁"
                        FontSize="14"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        ToolTip="Показать/скрыть пароль"
                        Click="TogglePasswordVisibility_Click"/>
            </Grid>
        </StackPanel>

        <!-- Подтверждение пароля -->
        <StackPanel Grid.Row="3" Margin="0,15,0,0">
            <TextBlock Text="Подтвердите пароль *:" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            <Grid>
                <PasswordBox x:Name="ConfirmPasswordBox" 
                             Style="{StaticResource RoundedPasswordBox}"
                             Height="40"
                             Padding="10,5,40,5"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                <TextBox x:Name="ConfirmPasswordTextBox"
                         Style="{StaticResource RoundedTextBox}"
                         Height="40"
                         Padding="10,5,40,5"
                         Visibility="Collapsed"
                         TextChanged="ConfirmPasswordTextBox_TextChanged"/>
                <Button x:Name="ToggleConfirmPasswordButton"
                        Width="26"
                        Height="26"
                        Content="👁"
                        FontSize="14"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        ToolTip="Показать/скрыть пароль"
                        Click="ToggleConfirmPasswordVisibility_Click"/>
            </Grid>
        </StackPanel>

        <!-- Роль -->
        <StackPanel Grid.Row="4" Margin="0,15,0,0">
            <TextBlock Text="Роль:" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            <ComboBox x:Name="RoleComboBox"
                      Height="40" 
                      Margin="0,0,0,0" 
                      Padding="10"
                      FontSize="14"
                      SelectedIndex="0">
                <ComboBoxItem Content="Администратор"/>
                <ComboBoxItem Content="Кассир"/>
                <ComboBoxItem Content="Кладовщик"/>
                <ComboBoxItem Content="Бухгалтер"/>
            </ComboBox>
        </StackPanel>

        <!-- ID сотрудника -->
        <StackPanel Grid.Row="5" Margin="0,15,0,0">
            <TextBlock Text="ID сотрудника (если есть):" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="EmployeeIdTextBox"
                     Style="{StaticResource RoundedTextBox}" 
                     Height="40" Loaded="QuantityTextBox_Loaded"/>
        </StackPanel>

        <!-- Сообщение об ошибке -->
        <Border x:Name="ErrorBorder"
                Grid.Row="6" 
                Margin="0,15,0,0"
                Background="#FFffee"
                BorderBrush="#e74c3c"
                BorderThickness="1"
                CornerRadius="5"
                Visibility="Collapsed">
            <Grid>
                <TextBlock x:Name="ErrorText" 
                           Foreground="#e74c3c" 
                           Margin="10,10,30,10"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"/>
                <Button Content="X"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,5,5,0"
                        Click="CloseErrorButton_Click"/>
            </Grid>
        </Border>

        <!-- Сообщение об успехе -->
        <Border x:Name="SuccessBorder"
                Grid.Row="7" 
                Margin="0,5,0,0"
                Background="#eeffee"
                BorderBrush="Green"
                BorderThickness="1"
                CornerRadius="5"
                Visibility="Collapsed">
            <Grid>
                <TextBlock x:Name="SuccessText" 
                           Foreground="Green" 
                           Margin="10,10,30,10"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"/>
                <Button Content="X"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,5,5,0"
                        Click="CloseSuccessButton_Click"/>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,20,0,10">
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Зарегистрироваться"
                    Width="160"
                    Height="45"
                    FontSize="16"
                    Margin="0,0,10,0"
                    Click="RegisterButton_Click"/>

            <Button Style="{StaticResource PrimaryButton}"
                    Content="Отмена"
                    Width="120"
                    Height="45"
                    FontSize="16"
                    Background="#95a5a6"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <!-- Подпись об обязательных полях -->
        <TextBlock Grid.Row="9" 
                   Text="* - обязательные поля"
                   Foreground="#999999"
                   FontSize="12"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>